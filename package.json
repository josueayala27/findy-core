{
  "type": "module",
  "scripts": {
    "build": "npx -y node@22.14.0 node_modules/nitro/dist/cli/index.mjs build",
    "dev": "npm run build && node scripts/sync-dev-vars.mjs && npx -y node@22.14.0 node_modules/wrangler/bin/wrangler.js dev --config .output/server/wrangler.json --port 3001",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run"
  },
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.1.4",
    "drizzle-kit": "^0.31.10",
    "hono": "^4.12.9",
    "jiti": "^2.7.0",
    "nitro": "latest",
    "tsx": "^4.20.6",
    "vitest": "*",
    "wrangler": "^4.107.0"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  }
}
